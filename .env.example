# BasePulse Environment Variables

# Database
DATABASE_URL=mysql://user:password@localhost:3306/basepulse

# Coinbase Developer Platform (CDP) SDK
CDP_API_KEY_NAME=
CDP_API_KEY_PRIVATE_KEY=

# Agent Configuration
AGENT_PRIVATE_KEY=
AGENT_OWNER_OPENID=

# Social Media APIs
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

NEYNAR_API_KEY=

# Analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Base Developer Platform — Registry API
# BASE_API_KEY: Bearer token for authenticated requests to base.org/api/registry
#   Format: bdev_... (get from base.dev > Settings > API Keys)
BASE_API_KEY=

# BASE_BUILDER_CODE: ERC-8021 attribution tag appended to all onchain transactions
#   as a dataSuffix so Base can attribute activity back to BasePulse.
#   Format: bc_... (get from base.dev > Settings > Builder Code)
#   Docs: https://docs.base.org/base-chain/builder-codes/app-developers
BASE_BUILDER_CODE=bc_hi2cipof
